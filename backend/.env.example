# SnapList Backend — Environment Variables
# Kopyala: cp .env.example .env

# Uygulama
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Görsel Arama API (henüz seçilmedi — mock modda boş bırak)
VISION_API_PROVIDER=mock   # mock | google_vision | serpapi | rekognition
GOOGLE_VISION_API_KEY=
SERPAPI_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS (extension origin)
ALLOWED_ORIGINS=chrome-extension://*,http://localhost:3000
