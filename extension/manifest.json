{
  "manifest_version": 3,
  "name": "Iris",
  "version": "0.2.0",
  "description": "Visual product search — snap any product, find where to buy it.",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://localhost:8000 http://127.0.0.1:8000;"
  },

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "action": {
    "default_title": "Open Iris"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "content.js",
        "auth.html",
        "auth.js",
        "collection.html",
        "collection.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
